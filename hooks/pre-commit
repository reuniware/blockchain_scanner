#!/bin/bash
# Pre-commit hook: run Mythril pattern tests before every commit.
# If tests fail, the commit is aborted.
#
# To install: copy this file to .git/hooks/pre-commit and make executable
#   cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# To bypass (emergency only):
#   git commit --no-verify

echo ""
echo "=== [pre-commit] Running Mythril pattern tests ==="
python test_mythril_patterns.py
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "!!! [pre-commit] TESTS FAILED (exit code $EXIT_CODE) !!!"
    echo "!!! Fix the issues or bypass with: git commit --no-verify  !!!"
    echo ""
    exit 1
fi

echo "=== [pre-commit] All tests passed ==="
echo ""
exit 0
